{
  "name": "synthetic-monitoring",
  "version": "1.0.0",
  "description": "Distributed synthetic monitoring system (拨测软件)",
  "private": true,
  "workspaces": [
    "server",
    "agent",
    "web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:agent\" \"npm run dev:web\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:agent": "npm run dev --workspace=agent",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspaces",
    "build:server": "npm run build --workspace=server",
    "build:agent": "npm run build --workspace=agent",
    "build:web": "npm run build --workspace=web"
  },
  "keywords": [
    "synthetic-monitoring",
    "distributed-monitoring",
    "uptime",
    "performance"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "pdf-parse": "^2.4.5"
  }
}
